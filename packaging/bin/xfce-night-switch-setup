#!/bin/bash
# Per-user setup for xfce-night-switch.
# Creates ~/.local/bin/ symlinks, initialises config and enables the systemd service.
set -euo pipefail

SHARE="/usr/share/xfce-night-switch"
CONFIG_DIR="$HOME/.config/xfce-night-switch"
BIN_DIR="$HOME/.local/bin"
APP_DIR="$HOME/.local/share/applications"
ICON_DIR="$HOME/.local/share/icons/hicolor/scalable/apps"

echo "=== xfce-night-switch setup for $USER ==="
echo ""

# ── Migrate old config/cache dirs ──────────────────────────────────────────
OLD_CFG="$HOME/.config/theme-switcher"
OLD_CACHE="$HOME/.cache/theme-switcher"
if [ -d "$OLD_CFG" ] && [ ! -d "$CONFIG_DIR" ]; then
    mv "$OLD_CFG" "$CONFIG_DIR"
    echo "Migrated: $OLD_CFG → $CONFIG_DIR"
fi
if [ -d "$OLD_CACHE" ] && [ ! -d "$HOME/.cache/xfce-night-switch" ]; then
    mv "$OLD_CACHE" "$HOME/.cache/xfce-night-switch"
    echo "Migrated: $OLD_CACHE → ~/.cache/xfce-night-switch"
fi

# ── ~/.local/bin/ symlinks ─────────────────────────────────────────────────
echo "Linking scripts to $BIN_DIR ..."
mkdir -p "$BIN_DIR"
for f in auto-theme.sh toggle-theme.sh theme-settings.sh \
          sunrise-sunset.py install-panel-launcher.sh auto-update.sh; do
    ln -sf "$SHARE/$f" "$BIN_DIR/$f"
    echo "  $BIN_DIR/$f"
done

# ── Config ─────────────────────────────────────────────────────────────────
echo ""
echo "Config ..."
mkdir -p "$CONFIG_DIR/locales"
if [ ! -f "$CONFIG_DIR/config" ]; then
    cp "$SHARE/config.default" "$CONFIG_DIR/config"
    echo "  created: $CONFIG_DIR/config"
else
    echo "  exists (not overwritten): $CONFIG_DIR/config"
fi

# Copy locale files without overwriting user edits
for f in "$SHARE/locales/"*.sh; do
    dst="$CONFIG_DIR/locales/$(basename "$f")"
    if [ ! -f "$dst" ]; then
        cp "$f" "$dst"
        echo "  locale: $(basename "$f")"
    fi
done

# ── Icon ───────────────────────────────────────────────────────────────────
echo ""
echo "Icon ..."
mkdir -p "$ICON_DIR"
cp /usr/share/icons/hicolor/scalable/apps/theme-moon.svg "$ICON_DIR/" 2>/dev/null \
    && echo "  copied: theme-moon.svg" || echo "  skipped (not found)"
gtk-update-icon-cache -f "$HOME/.local/share/icons/hicolor/" 2>/dev/null || true

# ── Desktop files ──────────────────────────────────────────────────────────
echo ""
echo "Desktop files ..."
mkdir -p "$APP_DIR"
for name in toggle-theme theme-settings; do
    src="/usr/share/applications/${name}.desktop"
    dst="$APP_DIR/${name}.desktop"
    # Replace the Exec= with $HOME-expanded path for ~/.local/bin
    sed "s|Exec=.*${name}|Exec=${BIN_DIR}/${name}.sh|" "$src" > "$dst"
    echo "  $dst"
done

# ── Panel launcher ─────────────────────────────────────────────────────────
echo ""
echo "Panel launcher ..."
if DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/$(id -u)/bus" \
   xfconf-query -c xfce4-panel -l >/dev/null 2>&1; then
    if bash "$BIN_DIR/install-panel-launcher.sh" 2>&1; then
        # install-panel-launcher.sh already handles the panel restart internally.
        # A second pkill here kills the panel before plugins initialize (breaks PulseAudio).
        echo "  launcher: installed"
    else
        echo "  launcher: install failed — add manually: right-click panel → Add New Items → Launcher"
    fi
else
    echo "  XFCE panel not accessible — run 'install-panel-launcher.sh' after login"
fi

# ── Systemd service ────────────────────────────────────────────────────────
echo ""
echo "Systemd service ..."
if systemctl --user show-environment >/dev/null 2>&1; then
    # Migrate: disable old service names from previous versions
    systemctl --user disable --now auto-theme-startup.service 2>/dev/null || true
    systemctl --user disable auto-update.service 2>/dev/null || true
    systemctl --user daemon-reload
    systemctl --user enable --now xfce-night-switch-startup.service 2>/dev/null \
        && echo "  xfce-night-switch-startup.service: enabled" \
        || echo "  xfce-night-switch-startup.service: could not enable — run: systemctl --user enable --now xfce-night-switch-startup.service"
    systemctl --user enable xfce-night-switch-update.service 2>/dev/null \
        && echo "  xfce-night-switch-update.service: enabled" \
        || echo "  xfce-night-switch-update.service: could not enable"
else
    echo "  systemd --user unavailable — run setup again from a graphical session"
fi

# ── Cron ───────────────────────────────────────────────────────────────────
echo ""
source "$CONFIG_DIR/config" 2>/dev/null || true
LOG_DIR="$HOME/.local/share/xfce-night-switch"
CRON_CMD="*/1 * * * * $BIN_DIR/auto-theme.sh >> $LOG_DIR/auto-theme.log 2>&1"
if [ "${AUTO_SWITCHER:-enabled}" = "enabled" ]; then
    mkdir -p "$LOG_DIR"
    if ! crontab -l 2>/dev/null | grep -q 'auto-theme.sh'; then
        (crontab -l 2>/dev/null; echo "$CRON_CMD") | crontab -
        echo "Cron: auto-theme.sh added (every minute, log: $LOG_DIR/auto-theme.log)"
    else
        # Migrate old entry without log redirect
        if ! crontab -l 2>/dev/null | grep -q 'auto-theme.log'; then
            crontab -l 2>/dev/null \
                | sed "s|.*/auto-theme\.sh.*|$CRON_CMD|" \
                | crontab -
            echo "Cron: updated (added log redirect)"
        else
            echo "Cron: already present"
        fi
    fi
fi

echo ""
echo "Done. Run 'theme-settings' to configure themes and icons."

# ── PR test confirmation ───────────────────────────────────────────────────
PR_NUM_FILE="$SHARE/PR_NUMBER"
if [ -f "$PR_NUM_FILE" ]; then
    PR_NUM=$(cat "$PR_NUM_FILE")
    PR_URL="https://github.com/prostopasta/xfce-night-switch/pull/${PR_NUM}"
    echo ""
    printf "┌─────────────────────────────────────────────────────┐\n"
    printf "│  🧪 TEST BUILD — PR #%-4s                           │\n" "$PR_NUM"
    printf "│  Check: panel visible · toggle works · settings OK  │\n"
    printf "└─────────────────────────────────────────────────────┘\n"

    # Build checklist rows: from TEST_PLAN file if present, else defaults
    _checklist_args=()
    TEST_PLAN_FILE="$SHARE/TEST_PLAN"
    if [ -f "$TEST_PLAN_FILE" ]; then
        while IFS= read -r line; do
            # Strip "- [ ] " prefix if present
            item="${line#- \[ \] }"
            item="${item#- }"
            [ -n "$item" ] && _checklist_args+=(FALSE "$item")
        done < "$TEST_PLAN_FILE"
    fi
    # Always add standard items
    _checklist_args+=(
        FALSE "Panel icon visible in taskbar"
        FALSE "Left-click toggles day ↔ night theme"
        FALSE "Arrow opens Theme Settings dialog"
        FALSE "No errors: journalctl --user -u xfce-night-switch-startup.service"
    )

    # Use yad checklist dialog (immune to background terminal output)
    _confirmed=false
    if command -v yad >/dev/null 2>&1 && [ -n "${DISPLAY:-}" ]; then
        _result=$(yad --list --checklist \
            --title="🧪 xfce-night-switch — Test Build PR #${PR_NUM}" \
            --text="<b>Check all items before confirming:</b>" \
            --column=":CHK" --column="Test item" \
            --print-all --separator="|" \
            "${_checklist_args[@]}" \
            --button="Confirm — all good:0" \
            --button="Cancel — found issues:1" \
            --width=520 --height=300 2>/dev/null) && {
            # All items must be TRUE
            if echo "$_result" | grep -q "^FALSE|"; then
                yad --warning \
                    --text="Please check all items before confirming." \
                    --button="OK:0" --width=300 2>/dev/null || true
            else
                _confirmed=true
            fi
        } || true
    elif [ -t 0 ] && [ -t 1 ]; then
        read -r -p "All checks passed? [y/N]: " yn
        [[ "${yn:-}" =~ ^[Yy]$ ]] && _confirmed=true
    fi

    if $_confirmed; then
        if command -v gh >/dev/null 2>&1 && gh auth status >/dev/null 2>&1; then
            gh pr comment "$PR_NUM" \
                --repo prostopasta/xfce-night-switch \
                --body '/test-passed' \
                && echo "Confirmed! PR #${PR_NUM} test gate passed." \
                || { echo "Could not post comment — confirm manually:"; echo "  $PR_URL"; }
        else
            echo "Post /test-passed on PR #${PR_NUM} to unblock merge:"
            echo "  $PR_URL"
        fi
    else
        echo "Please comment what failed on PR #${PR_NUM}:"
        echo "  $PR_URL"
    fi
fi
